package-as: FeedTillers
wowi-archive-previous: no

externals:
  Libs/LibStub: https://repos.curseforge.com/wow/libstub/trunk
  Libs/CallbackHandler-1.0: https://repos.curseforge.com/wow/callbackhandler/trunk/CallbackHandler-1.0
  Libs/LibQTip-2.0: https://repos.curseforge.com/wow/libqtip-2-0/trunk/LibQTip-2.0
  Libs/LibDataBroker-1.1: https://repos.curseforge.com/wow/libdatabroker-1-1/trunk

optional-dependencies:
  - tomtom

ignore:
  - Libs/LibStub/tests
  - Libs/*/*.txt
  - Libs/*/*.textile
  - Libs/*/*.md
  - Libs/*/*.toc
  - README.md