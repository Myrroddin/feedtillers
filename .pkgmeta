package-as: FeedTillers
wowi-archive-previous: no

externals:
  Libs/LibStub: https://repos.curseforge.com/wow/libstub/trunk
  Libs/LibQTip-1.0: https://repos.curseforge.com/wow/libqtip-1-0
  Libs/LibDataBroker-1.1:
    url: https://github.com/tekkub/libdatabroker-1-1/
    curse-slug: libdatabroker-1-1

optional-dependencies:
  - tomtom

ignore:
  - Libs/LibStub/tests
  - Libs/*/*.txt
  - Libs/*/*.textile
  - Libs/*/*.md
  - Libs/*/*.toc
  - Libs/LibQTip-1.0/LibStub
  - README.md